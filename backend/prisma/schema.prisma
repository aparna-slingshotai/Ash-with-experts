generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                String          @id @default(uuid())
  userId            String          @default("default-user")
  recordedAt        DateTime
  source            String          @default("ash-extension")
  rawTranscript     String
  labeledTranscript Json
  contextWindow     Json?
  createdAt         DateTime        @default(now())
  messages          ThreadMessage[]
}

model ThreadMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Debrief {
  id                   String    @id @default(uuid())
  userId               String    @default("default-user")
  ventTranscript       String    @default("")
  questionnaireAnswers Json      @default("{}")
  qaHistory            Json      @default("[]")
  insight              Json?
  rememberDebrief      Boolean   @default(false)
  rememberAnswers      Boolean   @default(false)
  rememberInsight      Boolean   @default(false)
  durationMinutes      Float     @default(0)
  createdAt            DateTime  @default(now())
  completedAt          DateTime?
}
